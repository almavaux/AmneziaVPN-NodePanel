# AmneziaWG API — environment variables
# Copy to .env and fill in your values

# ── Required ────────────────────────────────────────────────────────────────
AWG_API_KEY=your-secret-api-key-here
# Public IP/host of THIS server. Used as Endpoint in client WG configs and master CA SAN.
# Leave empty: the installer auto-detects the public IP at install time.
AWG_SERVER_HOST=
# Comma-separated API caller allow-list. Empty = filter off (only X-API-Key is enforced).
# On a node this is filled automatically by the master panel during enrollment.
AWG_ALLOWED_IPS=
# Role: "master" runs the web panel and CA. "node" runs only the node API and waits for master enrollment.
AWG_ROLE=master
# Required only for node role. Ignored on master.
AWG_MASTER_IP=

# ── Optional (defaults shown) ────────────────────────────────────────────────
# For new amneziawg-tools containers use amnezia-awg2; for legacy use amnezia-awg
AWG_CONTAINER_NAME=amnezia-awg2
# Mode: auto (probe binary), new (force awg+awg0), legacy (force wg+wg0)
AWG_MODE=auto
AWG_CONF_PATH=/opt/amnezia/awg/awg0.conf
AWG_CLIENTS_TABLE_PATH=/opt/amnezia/awg/clientsTable
AWG_PSK_KEY_PATH=/opt/amnezia/awg/wireguard_psk.key
AWG_SERVER_PUBKEY_PATH=/opt/amnezia/awg/wireguard_server_public_key.key
AWG_DNS=1.1.1.1
AWG_DOCKER_SOCKET=unix:///var/run/docker.sock

# ── gRPC + mTLS + bootstrap ───────────────────────────────────────────────
AWG_GRPC_PORT=50051
AWG_BOOTSTRAP_ENABLED=true
AWG_BOOTSTRAP_PATH=/node/bootstrap
AWG_STATE_DIR=/service/state
AWG_CA_CERT_PATH=/service/state/pki/ca.crt
AWG_CA_KEY_PATH=/service/state/pki/ca.key
AWG_MASTER_CERT_PATH=/service/state/pki/master.crt
AWG_MASTER_KEY_PATH=/service/state/pki/master.key
AWG_NODE_CERT_PATH=/service/state/pki/node.crt
AWG_NODE_KEY_PATH=/service/state/pki/node.key
AWG_NODE_ID_FILE=/service/state/node_id
AWG_NODE_REGISTRY_FILE=/service/state/nodes.json
AWG_ENROLLED_FLAG_FILE=/service/state/enrolled.flag
AWG_MASTER_LOCK_FILE=/service/state/master.lock
