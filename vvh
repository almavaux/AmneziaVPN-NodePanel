#!/usr/bin/env bash
set -euo pipefail

APP_DIR="/opt/awg-api"
REPO_URL="https://github.com/almavaux/AmneziaVPN-NodePanel.git"
COMPOSE_FILE="$APP_DIR/docker/docker-compose.yml"

usage() {
  cat <<EOF
vespervauxhall (vvh)

Usage:
  vvh menu
  vvh install [node]
  vvh update
  vvh reinstall
  vvh uninstall
  vvh status
  vvh logs
  vvh role [master|node]
  vvh enable
  vvh disable

Notes:
  - install         = full install as master (default)
  - install node    = full install as node (asks for master IP)
  - update          = safe update (keeps .env and state)
  - reinstall       = full clean reinstall (keeps current role if .env exists)
  - role            = toggle current role (master <-> node)
  - role master|node = set explicit role and restart
  - enable/disable  = start/stop panel services
EOF
}

# ──────────────────────────────────────────────────────────────────────────────
# helpers

resolve_compose() {
  if docker compose version >/dev/null 2>&1; then
    echo "docker compose -f $COMPOSE_FILE"
  elif command -v docker-compose >/dev/null 2>&1; then
    echo "docker-compose -f $COMPOSE_FILE"
  else
    echo ""
  fi
}

require_installed() {
  if [ ! -f "$APP_DIR/.env" ] || [ ! -f "$COMPOSE_FILE" ]; then
    echo "ERROR: panel is not installed at $APP_DIR. Run 'vvh install' first." >&2
    exit 1
  fi
}

current_role() {
  local env_file="$APP_DIR/.env"
  if [ ! -f "$env_file" ]; then
    echo ""
    return
  fi
  local r
  r="$(grep -E '^AWG_ROLE=' "$env_file" | tail -n1 | cut -d= -f2- | tr -d '"' || true)"
  echo "${r:-master}"
}

set_env_var() {
  # set_env_var <file> <KEY> <value>
  local file="$1" key="$2" value="$3"
  if [ ! -f "$file" ]; then
    echo "$key=$value" > "$file"
    return
  fi
  if grep -qE "^${key}=" "$file"; then
    # use a tmp file for portability across BSD/GNU sed
    awk -v k="$key" -v v="$value" 'BEGIN{FS=OFS="="} $1==k{print k"="v; next} {print}' "$file" > "$file.tmp"
    mv "$file.tmp" "$file"
  else
    echo "$key=$value" >> "$file"
  fi
}

sync_env_to_compose() {
  local src="$APP_DIR/.env"
  if [ -f "$src" ]; then
    mkdir -p "$APP_DIR/docker"
    cp "$src" "$APP_DIR/docker/.env"
  fi
}

restart_stack() {
  local cmd
  cmd="$(resolve_compose)"
  if [ -z "$cmd" ]; then
    echo "ERROR: docker compose is not available" >&2
    exit 1
  fi
  echo "==> Restarting stack"
  eval "$cmd up -d --force-recreate"
}

stop_stack() {
  local cmd
  cmd="$(resolve_compose)"
  if [ -n "$cmd" ]; then
    eval "$cmd down --remove-orphans" >/dev/null 2>&1 || true
  fi
}

is_panel_enabled() {
  docker ps --format '{{.Names}}' 2>/dev/null | grep -Fxq 'awg-api'
}

enable_panel() {
  require_installed
  if is_panel_enabled; then
    echo "Panel is already enabled."
    return 0
  fi
  echo "==> Enabling panel"
  restart_stack
}

disable_panel() {
  require_installed
  if ! is_panel_enabled; then
    echo "Panel is already disabled."
    return 0
  fi
  echo "==> Disabling panel"
  stop_stack
}

wipe_state() {
  # Role-specific PKI/identity is incompatible across roles, so wipe it on switch.
  rm -rf "$APP_DIR/state"
  mkdir -p "$APP_DIR/state"
}

# ──────────────────────────────────────────────────────────────────────────────
# install / update / lifecycle

run_deploy() {
  local mode="$1"
  if [ ! -x "$APP_DIR/deploy.sh" ]; then
    echo "deploy.sh not found locally, using GitHub bootstrap..."
    curl -fsSL "https://raw.githubusercontent.com/almavaux/AmneziaVPN-NodePanel/main/deploy.sh" | bash -s -- "$mode"
    return
  fi
  bash "$APP_DIR/deploy.sh" "$mode" --repo "$REPO_URL" --dir "$APP_DIR"
}

container_exists() {
  docker ps -a --format '{{.Names}}' 2>/dev/null | grep -Fxq 'awg-api'
}

do_uninstall() {
  echo "==> Uninstalling panel"
  local cmd
  cmd="$(resolve_compose)"
  if [ -f "$COMPOSE_FILE" ] && [ -n "$cmd" ]; then
    eval "$cmd down --remove-orphans" || true
  fi
  if container_exists; then
    docker rm -f awg-api >/dev/null 2>&1 || true
  fi
  rm -rf "$APP_DIR"
  echo "Done. $APP_DIR removed."
}

do_status() {
  local installed="no"
  local role="unknown"
  local panel_state="disabled"
  local health_state="unreachable"

  if [ -f "$APP_DIR/.env" ] && [ -f "$COMPOSE_FILE" ]; then
    installed="yes"
    role="$(current_role 2>/dev/null || echo unknown)"
  fi

  if is_panel_enabled; then
    panel_state="enabled (running)"
  fi

  if curl -fsS http://127.0.0.1:8000/health >/dev/null 2>&1; then
    health_state="ok"
  fi

  echo ""
  echo "=== Panel status ==="
  echo "Installed : $installed"
  echo "Role      : $role"
  echo "Panel     : $panel_state"
  echo "Health    : $health_state (http://127.0.0.1:8000/health)"
  echo ""
}

do_logs() {
  if ! container_exists; then
    echo "Container awg-api not found. Run 'vvh install' first."
    return 1
  fi
  docker logs --tail 100 -f awg-api
}

# ──────────────────────────────────────────────────────────────────────────────
# role management

apply_role() {
  # apply_role <new_role> [master_ip]
  local new_role="$1"
  local master_ip="${2:-}"
  local env_file="$APP_DIR/.env"

  case "$new_role" in
    master|node) ;;
    *) echo "ERROR: role must be 'master' or 'node'" >&2; return 1 ;;
  esac

  require_installed

  local cur
  cur="$(current_role)"
  if [ "$cur" = "$new_role" ]; then
    echo "Role is already '$new_role'. Nothing to do."
    return 0
  fi

  if [ "$new_role" = "node" ] && [ -z "$master_ip" ]; then
    read -r -p "Master IP for this node: " master_ip
    if [ -z "$master_ip" ]; then
      echo "ERROR: master IP is required for node role" >&2
      return 1
    fi
  fi

  echo "==> Switching role: $cur -> $new_role"
  echo "    State at $APP_DIR/state will be wiped (PKI/node identity/registry)."
  read -r -p "Continue? [y/N]: " ans
  case "$ans" in
    y|Y|yes|YES) ;;
    *) echo "Cancelled."; return 0 ;;
  esac

  set_env_var "$env_file" "AWG_ROLE" "$new_role"
  if [ "$new_role" = "node" ]; then
    set_env_var "$env_file" "AWG_MASTER_IP" "$master_ip"
  else
    # master ignores AWG_MASTER_IP; clear it to avoid confusion
    set_env_var "$env_file" "AWG_MASTER_IP" ""
  fi

  sync_env_to_compose
  stop_stack
  wipe_state
  restart_stack

  echo ""
  echo "Done. Role is now '$new_role'."
  if [ "$new_role" = "master" ]; then
    echo "Web panel: http://127.0.0.1:8000  (Node management is now available)"
  else
    echo "Bootstrap is enabled. From master panel: add this node by its IP."
  fi
}

do_role() {
  # do_role               -> toggle
  # do_role master|node   -> set explicit
  require_installed

  local target="${1:-}"
  local cur
  cur="$(current_role)"

  if [ -z "$target" ]; then
    if [ "$cur" = "master" ]; then
      target="node"
    else
      target="master"
    fi
  fi

  apply_role "$target"
}

# ──────────────────────────────────────────────────────────────────────────────
# install entry points

do_install() {
  # do_install                -> install as master (default)
  # do_install node           -> install as node (will prompt for master IP)
  local target_role="${1:-master}"

  case "$target_role" in
    master|node) ;;
    *) echo "ERROR: install role must be 'master' or 'node'" >&2; exit 1 ;;
  esac

  local master_ip=""
  if [ "$target_role" = "node" ]; then
    read -r -p "Master IP for this node: " master_ip
    if [ -z "$master_ip" ]; then
      echo "ERROR: master IP is required for node role" >&2
      exit 1
    fi
  fi

  run_deploy install

  if [ "$target_role" = "node" ]; then
    # The default install lands as master (per .env.example). Switch to node now.
    set_env_var "$APP_DIR/.env" "AWG_ROLE" "node"
    set_env_var "$APP_DIR/.env" "AWG_MASTER_IP" "$master_ip"
    sync_env_to_compose
    stop_stack
    wipe_state
    restart_stack
    echo ""
    echo "Done. Installed as node. Master: $master_ip"
  fi
}

# ──────────────────────────────────────────────────────────────────────────────
# menu

menu() {
  while true; do
    local cur
    local role_action
    local panel_action
    cur="$(current_role 2>/dev/null || echo unknown)"
    if [ "$cur" = "master" ]; then
      role_action="Switch role to Node"
    else
      role_action="Switch role to Master"
    fi
    if is_panel_enabled; then
      panel_action="Disable panel"
    else
      panel_action="Enable panel"
    fi
    echo ""
    echo "=== vespervauxhall (vvh) ==="
    echo "Current role: $cur"
    echo "1) Install panel (master)"
    echo "2) Install as node"
    echo "3) Update panel"
    echo "4) Reinstall panel (clean)"
    echo "5) Uninstall panel"
    echo "6) Status"
    echo "7) Logs"
    echo "8) $role_action"
    echo "9) $panel_action"
    echo "0) Exit"
    read -r -p "Select option [0-9]: " answer
    case "$answer" in
      1) do_install master ;;
      2) do_install node ;;
      3) run_deploy update ;;
      4) run_deploy install ;;
      5) do_uninstall ;;
      6) do_status ;;
      7) do_logs ;;
      8) do_role ;;
      9)
        if is_panel_enabled; then
          disable_panel
        else
          enable_panel
        fi
        ;;
      0) exit 0 ;;
      *) echo "Unknown option" ;;
    esac
  done
}

main() {
  local cmd="${1:-menu}"
  case "$cmd" in
    menu) menu ;;
    install) shift || true; do_install "${1:-master}" ;;
    update) run_deploy update ;;
    reinstall) run_deploy install ;;
    uninstall) do_uninstall ;;
    status) do_status ;;
    logs) do_logs ;;
    role) shift || true; do_role "${1:-}" ;;
    enable) enable_panel ;;
    disable) disable_panel ;;
    -h|--help|help) usage ;;
    *)
      echo "Unknown command: $cmd" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
